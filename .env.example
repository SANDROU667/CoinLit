# Required on Vercel.
# Generate a long random value, for example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-strong-random-secret

# Admin panel credentials. Change these before public production launch if needed.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123321

# Required on Vercel. Use a hosted MySQL-compatible database.
# Example format:
# DATABASE_URL=mysql://user:password@host:3306/database
DATABASE_URL=
