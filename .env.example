# Required on Vercel.
# Generate a long random value, for example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-strong-random-secret

# Admin panel credentials. Change these before public production launch if needed.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123321

# Required on Vercel. Use Neon or another hosted Postgres database.
# Example format:
# POSTGRES_URL=postgres://user:password@host:5432/database
POSTGRES_URL=

# Optional fallback if your provider exposes DATABASE_URL instead of POSTGRES_URL.
DATABASE_URL=
